# Copy this file to .env and fill in your values
# cp .env.example .env

# ── LLM backends ──────────────────────────────────────────────────
# Ollama (local, no key needed — just run: ollama serve)
OLLAMA_HOST=http://localhost:11434

# Claude (cloud — get key at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS S3 (optional, only for s3 ingestion mode) ─────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
MVI_S3_BUCKET=mvi-video-input

# ── Redis (optional, falls back to in-memory) ─────────────────────
MVI_ORCHESTRATION__REDIS__HOST=localhost
MVI_ORCHESTRATION__REDIS__PORT=6379

# ── Qdrant (optional, for speaker embeddings) ─────────────────────
MVI_ASR_AGENT__QDRANT__HOST=localhost
MVI_ASR_AGENT__QDRANT__PORT=6333

# ── Log level ─────────────────────────────────────────────────────
LOG_LEVEL=INFO
